{
	"name": "@mm-preview/sdk",
	"version": "0.1.0",
	"private": true,
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./query-client": "./src/query-client.ts",
		"./react-query/next": "./src/react-query/next.ts"
	},
	"scripts": {
		"lint": "biome check",
		"postinstall": "node scripts/create-stubs.js",
		"test": "vitest run",
		"type-check": "npm run generate && tsc --noEmit",
		"check": "npm run lint && npm run type-check",
		"fetch:openapi": "node scripts/fetch-openapi.js",
		"generate": "orval --config orval.config.js",
		"generate:all": "npm run fetch:openapi && npm run generate"
	},
	"dependencies": {
		"@hey-api/client-fetch": "^0.7.0",
		"@tanstack/react-query": "^5.90.2",
		"axios": "^1.16.0",
		"socket.io-client": "^4.8.3",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@types/node": "^20",
		"@types/react": "^19.2.3",
		"orval": "^7.13.2",
		"typescript": "^5",
		"vitest": "^2.1.8"
	},
	"peerDependencies": {
		"react": "^19.2.3"
	}
}
